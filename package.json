{
  "name": "browser-agentbridge-ai",
  "version": "3.2.5",
  "description": "Human-paced browser control bridge based on Playwright",
  "type": "module",
  "bin": {
    "agentbridge": "./dist/cli/bridge.js",
    "agentbridge-live": "./dist/cli/live.js",
    "agentbridge-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "live": "tsx src/cli/live.ts",
    "mcp": "tsx src/mcp.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "docs:api": "tsx scripts/gen-api-docs.ts",
    "benchmark": "tsx scripts/benchmark.ts",
    "prepare": "npm run build || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "libphonenumber-js": "^1.12.42",
    "playwright": "^1.59.1",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "eslint": "^9.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.12.0",
    "vitest": "^4.1.5"
  },
  "main": "dist/server.js",
  "files": [
    "bin/",
    "dist/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "types": "dist/server.d.ts",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexandre-leng/AgentBridge-AI.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
