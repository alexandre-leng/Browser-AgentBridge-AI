{
  "name": "openclaw-browser-bridge",
  "version": "3.0.0",
  "description": "Pont de contrôle navigateur humain basé sur Playwright",
  "type": "module",
  "bin": {
    "openclaw-live": "./dist/cli/live.js"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "live": "tsx src/cli/live.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "docs:api": "tsx scripts/gen-api-docs.ts"
  },
  "dependencies": {
    "libphonenumber-js": "^1.12.42",
    "playwright": "^1.59.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "eslint": "^9.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.12.0",
    "vitest": "^4.1.5"
  }
}
