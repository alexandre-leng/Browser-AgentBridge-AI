{
  "manifest_version": 3,
  "name": "OpenClaw Browser Bridge",
  "version": "3.2.1",
  "description": "Bridge entre OpenClaw et Chrome pour recherches et actions web",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-polyfill.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16_red.png",
      "48": "icons/icon48_red.png",
      "128": "icons/icon128_red.png"
    }
  },
  "icons": {
    "16": "icons/icon16_simplified.svg",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://localhost:8080/ http://localhost:8080/ ws://127.0.0.1:8080/ http://127.0.0.1:8080/"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js", "browser-polyfill.js"],
      "matches": ["<all_urls>"]
    }
  ]
}